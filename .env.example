APP_ENV=development
LOG_LEVEL=info

DB_HOST=
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_PORT=5432
DB_SSLMODE=disable

GITHUB_TOKEN=
GITHUB_TIMEOUT_SECONDS=15
GITHUB_CACHE_TTL_SECONDS=600
GITHUB_CACHE_ERROR_TTL_SECONDS=60

SCANNER_WORKERS=3
SCANNER_QUEUE_SIZE=100
SCANNER_SAFETY_BUFFER=0.1            # api tokens safety buffer
SCANNER_PRODUCER_INTERVAL_SECONDS=60 # interval between batches
SCANNER_MIN_INTERVAL_SECONDS=900     # interval between specific repo scans

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

REDIS_ADDR=localhost:6379

RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_MAX_RETRY_ATTEMPTS=5        # retry tiers before dead-lettering (shared)
RABBITMQ_RETRY_TTL_SECONDS=30        # base backoff delay (tier 0)
RABBITMQ_RETRY_BACKOFF_FACTOR=2      # tier i delay = base * factor^i

NOTIFIER_WORKERS=3
NOTIFIER_PREFETCH_COUNT=10
NOTIFIER_DEDUP_TTL_HOURS=24          # how long processed event IDs are remembered

MAILER_WORKERS=3
MAILER_PREFETCH_COUNT=10